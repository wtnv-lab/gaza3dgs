AddDefaultCharset UTF-8

AddType application/octet-stream .spz
AddType application/ply .ply

<IfModule mod_brotli.c>
    SetEnvIfNoCase Request_URI "\.(?:spz|ply)$" no-brotli dont-vary
</IfModule>

<IfModule mod_deflate.c>
    SetEnvIfNoCase Request_URI "\.(?:spz|ply)$" no-gzip dont-vary
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(spz|ply)$">
        Header unset Content-Encoding
    </FilesMatch>
    <FilesMatch "\.spz$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.ply$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType application/octet-stream "access plus 1 year"
    ExpiresByType application/ply "access plus 1 year"
</IfModule>
